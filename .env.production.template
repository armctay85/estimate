# EstiMate Production Environment Template
# Copy to .env.production and fill in values

# Database
DATABASE_URL=postgresql://user:password@host:5432/estimate?sslmode=require

# JWT Secret (generate strong random string)
JWT_SECRET=your-super-secure-jwt-secret-min-64-characters
JWT_EXPIRES_IN=7d

# Session Secret
SESSION_SECRET=your-super-secure-session-secret-min-64-characters

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PRO_PLUS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@estimate-app.com

# Storage (AWS S3 or compatible)
STORAGE_ENDPOINT=s3.amazonaws.com
STORAGE_BUCKET=estimate-uploads
STORAGE_ACCESS_KEY_ID=...
STORAGE_SECRET_ACCESS_KEY=...
STORAGE_REGION=us-east-1

# Rate Limiting (Redis optional)
REDIS_URL=redis://localhost:6379

# Monitoring
SENTRY_DSN=https://...@sentry.io/...

# Feature Flags
ENABLE_COST_DATABASE=true
ENABLE_PDF_TAKEOFF=true
ENABLE_TENDER_ANALYZER=true
ENABLE_QUOTE_VALIDATOR=true

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
